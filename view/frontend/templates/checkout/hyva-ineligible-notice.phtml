<?php
/**
 * Hyvä Checkout ineligibility notice — Tailwind + Alpine.js.
 *
 * Dark-mode variants, fade-in/out transitions that respect prefers-reduced-motion,
 * and role="alert" + aria-live so screen readers announce the restriction.
 *
 * @var \ETechFlow\NextDayEligibility\ViewModel\HyvaCheckoutNotice $viewModel
 * @var \Magento\Framework\Escaper $escaper
 *
 * --- Tailwind safelist ---
 * The container/icon/ring classes below are emitted by HyvaCheckoutNotice::getStyleClasses(),
 * which lives in a .php file that Hyvä's default content scan does NOT cover. Repeat the full
 * set here so Tailwind's class detection (which reads .phtml file text as a string) keeps
 * every utility class through the purge step. Works for Tailwind 3 and 4.
 *
 *   bg-blue-50 text-blue-900 border-blue-500 dark:bg-blue-900/20 dark:text-blue-200 dark:border-blue-400
 *   text-blue-600 dark:text-blue-300 focus:ring-blue-500 dark:focus:ring-blue-400
 *   bg-red-50 text-red-900 border-red-500 dark:bg-red-900/20 dark:text-red-200 dark:border-red-400
 *   text-red-600 dark:text-red-300 focus:ring-red-500 dark:focus:ring-red-400
 *   bg-amber-50 text-amber-900 border-amber-500 dark:bg-amber-900/20 dark:text-amber-200 dark:border-amber-400
 *   text-amber-600 dark:text-amber-300 focus:ring-amber-500 dark:focus:ring-amber-400
 *
 * --- Dedup guard (v1.4.1+) ---
 * `hyva_checkout_index_index.xml` references this notice from three different Hyvä Checkout
 * containers because different Hyvä Checkout versions expose different container names — at
 * least one of the three has to be live for the notice to render at all. To avoid the
 * "two containers both exist" double-render edge case, a static $alreadyRendered flag in
 * THIS file short-circuits the second include. First include claims it; second sees it
 * set and returns. Cheap, server-side, no JS coordination needed.
 */
$viewModel = $block->getData('view_model');

if (!$viewModel || !$viewModel->isVisible()) {
    return;
}

static $alreadyRendered = false;
if ($alreadyRendered) {
    return;
}
$alreadyRendered = true;

$styles = $viewModel->getStyleClasses();
$styleType = $viewModel->getStyleType();
?>
<?php /* Inline critical CSS — guarantees the notice's box + colour even when the store's
         compiled Tailwind build does not include this module's colour utility classes
         (e.g. a dev store serving borrowed production static, where getStyleClasses()'
         classes were never built). :where() has 0 specificity, so a Tailwind class that IS
         present always wins and appearance is unchanged; these rules only fill the gap. */ ?>
<style>
    :where(.etechflow-nextday-notice){display:flex;align-items:flex-start;gap:12px;padding:16px;margin:0 0 24px;border-radius:6px;border-left-width:4px;border-left-style:solid;box-shadow:0 1px 2px rgba(0,0,0,.05);font-size:14px;line-height:1.5}
    :where(.etechflow-nextday-notice--warning){background-color:#fff8e1;border-left-color:#f57c00;color:#5d4037}
    :where(.etechflow-nextday-notice--info){background-color:#e3f2fd;border-left-color:#1976d2;color:#0d47a1}
    :where(.etechflow-nextday-notice--error){background-color:#fce4ec;border-left-color:#c62828;color:#b71c1c}
</style>
<div x-data="{ visible: true, show: false }"
     x-init="$nextTick(() => show = true)"
     x-show="visible && show"
     x-cloak
     x-transition:enter="motion-safe:transition motion-safe:ease-out motion-safe:duration-300"
     x-transition:enter-start="motion-safe:opacity-0 motion-safe:-translate-y-2"
     x-transition:enter-end="motion-safe:opacity-100 motion-safe:translate-y-0"
     x-transition:leave="motion-safe:transition motion-safe:ease-in motion-safe:duration-150"
     x-transition:leave-start="motion-safe:opacity-100"
     x-transition:leave-end="motion-safe:opacity-0"
     role="alert"
     aria-live="assertive"
     class="etechflow-nextday-notice etechflow-nextday-notice--<?= $escaper->escapeHtmlAttr($styleType) ?> border-l-4 rounded-md p-4 mb-6 flex items-start gap-3 shadow-sm <?= $escaper->escapeHtmlAttr($styles['container']) ?>">

    <!-- Warning triangle (Heroicons solid) -->
    <svg class="w-6 h-6 flex-shrink-0 mt-0.5 <?= $escaper->escapeHtmlAttr($styles['icon']) ?>"
         fill="currentColor"
         viewBox="0 0 24 24"
         aria-hidden="true">
        <path fill-rule="evenodd"
              d="M9.401 3.003c1.155-2 4.043-2 5.197 0l7.355 12.748c1.154 2-.29 4.5-2.599 4.5H4.645c-2.309 0-3.752-2.5-2.598-4.5L9.4 3.003zM12 8.25a.75.75 0 01.75.75v3.75a.75.75 0 01-1.5 0V9a.75.75 0 01.75-.75zm0 8.25a.75.75 0 100-1.5.75.75 0 000 1.5z"
              clip-rule="evenodd"/>
    </svg>

    <div class="flex-1 min-w-0">
        <strong class="block font-bold text-base mb-1">
            <?= $escaper->escapeHtml($viewModel->getTitle()) ?>
        </strong>
        <span class="text-sm opacity-90 block">
            <?= $escaper->escapeHtml($viewModel->getMessage()) ?>
        </span>
    </div>

    <button type="button"
            @click="visible = false"
            class="flex-shrink-0 p-1 -m-1 rounded hover:bg-black/5 dark:hover:bg-white/10 transition focus:outline-none focus:ring-2 <?= $escaper->escapeHtmlAttr($styles['ring']) ?>"
            aria-label="<?= $escaper->escapeHtmlAttr(__('Dismiss notice')) ?>">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
    </button>
</div>
